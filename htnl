<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes">
    <title>SSB2 — Мониторинг читеров</title>
    <style>
        /* ====== ВСЕ СТИЛИ (без изменений) ====== */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Roboto, system-ui, sans-serif;
            background: #080c14;
            color: #e8edf5;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 20px;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(43, 108, 143, 0.10) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(90, 63, 107, 0.10) 0%, transparent 60%),
                linear-gradient(180deg, #0b111e 0%, #0b0e14 100%);
            background-attachment: fixed;
        }

        .container {
            max-width: 1200px;
            width: 100%;
            background: rgba(18, 28, 45, 0.88);
            backdrop-filter: blur(16px);
            border-radius: 40px;
            padding: 28px 24px 34px;
            box-shadow:
                0 40px 80px rgba(0, 0, 0, 0.8),
                inset 0 1px 0 rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(61, 87, 117, 0.25);
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .container::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(ellipse at center, rgba(43, 108, 143, 0.04) 0%, transparent 70%);
            pointer-events: none;
            animation: rotateGlow 60s linear infinite;
        }
        @keyframes rotateGlow {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        h1 {
            font-weight: 700;
            font-size: 28px;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 10px 16px;
            margin-bottom: 4px;
            position: relative;
            z-index: 1;
            letter-spacing: -0.5px;
        }
        h1 .accent { color: #3f8bb3; }
        h1 small {
            font-weight: 400;
            font-size: 15px;
            color: #6e8aa6;
            letter-spacing: 0.3px;
            background: rgba(0, 0, 0, 0.3);
            padding: 2px 14px;
            border-radius: 30px;
            border: 1px solid rgba(61, 87, 117, 0.3);
        }
        .subtitle {
            color: #7a94b2;
            margin-bottom: 20px;
            font-size: 14px;
            border-left: 3px solid #3f8bb3;
            padding-left: 16px;
            line-height: 1.5;
            position: relative;
            z-index: 1;
        }

        .tabs {
            display: flex;
            gap: 6px;
            margin-bottom: 24px;
            border-bottom: 1px solid rgba(61, 87, 117, 0.2);
            padding-bottom: 10px;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }
        .tab-btn {
            background: transparent;
            border: none;
            color: #6e8aa6;
            padding: 8px 20px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 30px;
            transition: 0.25s;
            border: 1px solid transparent;
            letter-spacing: 0.3px;
        }
        .tab-btn:hover {
            background: rgba(43, 108, 143, 0.12);
            color: #c8dae8;
        }
        .tab-btn.active {
            background: rgba(43, 108, 143, 0.2);
            color: #fff;
            border-color: #3f8bb3;
            box-shadow: 0 0 20px rgba(43, 108, 143, 0.15);
        }
        .tab-content { display: none; animation: fadeIn 0.3s ease; }
        .tab-content.active { display: block; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .last-update {
            color: #5a7a96;
            font-size: 13px;
            margin-bottom: 18px;
            text-align: right;
            position: relative;
            z-index: 1;
            opacity: 0.8;
        }

        .regions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 18px;
            margin-bottom: 30px;
            position: relative;
            z-index: 1;
        }

        .region-card {
            background: rgba(26, 40, 60, 0.6);
            backdrop-filter: blur(4px);
            border-radius: 20px;
            padding: 18px 12px 16px;
            text-align: center;
            border: 1px solid rgba(61, 87, 117, 0.2);
            transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
        }
        .region-card:hover {
            transform: translateY(-6px) scale(1.01);
            border-color: rgba(63, 139, 179, 0.5);
            box-shadow: 0 16px 32px rgba(0, 0, 0, 0.5), 0 0 40px rgba(43, 108, 143, 0.08);
        }

        .region-name {
            font-weight: 600;
            font-size: 17px;
            margin-bottom: 12px;
            color: #d6e0ee;
            letter-spacing: 0.2px;
        }
        .region-name .label {
            font-weight: 400;
            color: #6e8aa6;
            font-size: 14px;
        }

        .status-indicator {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        .circle {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            margin: 0 auto 6px;
            box-shadow: 0 0 0 2px rgba(45, 59, 78, 0.5), 0 0 24px rgba(0, 0, 0, 0.4);
            transition: background 0.4s ease, box-shadow 0.4s ease;
            will-change: transform;
        }

        @keyframes pulse-green {
            0% { transform: scale(1); box-shadow: 0 0 0 2px rgba(46, 155, 94, 0.3), 0 0 20px rgba(46, 155, 94, 0.1); }
            50% { transform: scale(1.06); box-shadow: 0 0 0 6px rgba(46, 155, 94, 0.15), 0 0 30px rgba(46, 155, 94, 0.2); }
            100% { transform: scale(1); box-shadow: 0 0 0 2px rgba(46, 155, 94, 0.3), 0 0 20px rgba(46, 155, 94, 0.1); }
        }
        @keyframes pulse-yellow {
            0% { transform: scale(1); box-shadow: 0 0 0 2px rgba(212, 184, 76, 0.3), 0 0 20px rgba(212, 184, 76, 0.1); }
            50% { transform: scale(1.12); box-shadow: 0 0 0 8px rgba(212, 184, 76, 0.15), 0 0 40px rgba(212, 184, 76, 0.25); }
            100% { transform: scale(1); box-shadow: 0 0 0 2px rgba(212, 184, 76, 0.3), 0 0 20px rgba(212, 184, 76, 0.1); }
        }
        @keyframes pulse-orange {
            0% { transform: scale(1); box-shadow: 0 0 0 2px rgba(217, 122, 43, 0.3), 0 0 20px rgba(217, 122, 43, 0.1); }
            50% { transform: scale(1.20); box-shadow: 0 0 0 12px rgba(217, 122, 43, 0.15), 0 0 50px rgba(217, 122, 43, 0.3); }
            100% { transform: scale(1); box-shadow: 0 0 0 2px rgba(217, 122, 43, 0.3), 0 0 20px rgba(217, 122, 43, 0.1); }
        }
        @keyframes pulse-red {
            0% { transform: scale(1); box-shadow: 0 0 0 2px rgba(197, 62, 62, 0.3), 0 0 20px rgba(197, 62, 62, 0.1); }
            50% { transform: scale(1.30); box-shadow: 0 0 0 16px rgba(197, 62, 62, 0.15), 0 0 60px rgba(197, 62, 62, 0.35); }
            100% { transform: scale(1); box-shadow: 0 0 0 2px rgba(197, 62, 62, 0.3), 0 0 20px rgba(197, 62, 62, 0.1); }
        }
        .pulse-green { animation: pulse-green 2.8s ease-in-out infinite; }
        .pulse-yellow { animation: pulse-yellow 2.2s ease-in-out infinite; }
        .pulse-orange { animation: pulse-orange 1.6s ease-in-out infinite; }
        .pulse-red { animation: pulse-red 1.0s ease-in-out infinite; }

        .status-label {
            font-size: 12px;
            font-weight: 500;
            color: #b0c2d6;
            background: rgba(15, 23, 34, 0.6);
            padding: 3px 14px;
            border-radius: 30px;
            display: inline-block;
            letter-spacing: 0.3px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(61, 87, 117, 0.15);
        }

        .cheater-count {
            font-size: 13px;
            color: #8fa0b8;
            margin-top: 4px;
            background: rgba(15, 23, 34, 0.5);
            padding: 2px 14px;
            border-radius: 30px;
            display: inline-block;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(61, 87, 117, 0.1);
        }

        .report-stats {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 6px 10px;
            margin-top: 10px;
            font-size: 12px;
            color: #b0c2d6;
            background: rgba(15, 23, 34, 0.4);
            padding: 4px 10px;
            border-radius: 30px;
            backdrop-filter: blur(4px);
        }
        .report-stats span {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .report-stats .dot {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 2px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .action-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 14px;
            margin-top: 6px;
            position: relative;
            z-index: 1;
        }
        .action-bar .left-group {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
        }
        .action-bar .cooldown {
            font-size: 13px;
            color: #6e8aa6;
            background: rgba(0, 0, 0, 0.3);
            padding: 4px 14px;
            border-radius: 30px;
            border: 1px solid rgba(61, 87, 117, 0.2);
            display: none;
            align-items: center;
            gap: 6px;
        }
        .action-bar .cooldown.show { display: inline-flex; }
        .action-bar .cooldown .time {
            font-weight: 600;
            color: #d6e0ee;
        }

        .btn {
            background: rgba(45, 63, 87, 0.7);
            backdrop-filter: blur(4px);
            border: none;
            color: #eef4fc;
            padding: 10px 24px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.25s;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(62, 86, 114, 0.3);
            touch-action: manipulation;
            letter-spacing: 0.2px;
        }
        .btn:hover {
            background: rgba(58, 82, 112, 0.8);
            transform: scale(1.02);
            box-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
            border-color: rgba(63, 139, 179, 0.4);
        }
        .btn:active { transform: scale(0.97); }
        .btn-primary {
            background: linear-gradient(135deg, #2b6c8f, #1f5577);
            border-color: #3f8bb3;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #3581a8, #26628a);
        }
        .btn-admin {
            background: linear-gradient(135deg, #5a3f6b, #4a2f5a);
            border-color: #7a4f8f;
        }
        .btn-admin:hover {
            background: linear-gradient(135deg, #6f4d82, #5a3f6b);
        }
        .btn-secondary {
            background: rgba(42, 58, 78, 0.7);
            border-color: #40566e;
        }
        .btn-secondary:hover {
            background: rgba(58, 80, 104, 0.8);
        }
        .btn-danger {
            background: linear-gradient(135deg, #8f3b3b, #6f2a2a);
            border-color: #b54a4a;
        }
        .btn-danger:hover {
            background: linear-gradient(135deg, #a84444, #8f3b3b);
        }
        .btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none !important;
        }

        .footer {
            margin-top: 34px;
            padding-top: 18px;
            border-top: 1px solid rgba(42, 54, 71, 0.5);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            color: #5a7a96;
            font-size: 14px;
            position: relative;
            z-index: 1;
        }
        .footer a {
            color: #3f8bb3;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }
        .footer a:hover {
            color: #5fa9d4;
            text-decoration: underline;
        }
        .footer .telegram-icon {
            display: inline-block;
            width: 22px;
            height: 22px;
            background: #3f8bb3;
            border-radius: 50%;
            color: #fff;
            text-align: center;
            line-height: 22px;
            font-weight: 700;
            font-size: 14px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 18px;
            margin: 22px 0;
        }
        .info-card {
            background: rgba(26, 40, 60, 0.5);
            backdrop-filter: blur(4px);
            border-radius: 16px;
            padding: 18px 16px;
            border-left: 4px solid #2d3b4e;
            border: 1px solid rgba(61, 87, 117, 0.15);
            transition: 0.2s;
        }
        .info-card:hover {
            border-color: rgba(63, 139, 179, 0.3);
            transform: translateY(-2px);
        }
        .info-card .level-dot {
            display: inline-block;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            margin-right: 8px;
            vertical-align: middle;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .info-card h4 {
            font-size: 16px;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            color: #d6e0ee;
        }
        .info-card p {
            font-size: 14px;
            color: #b0c2d6;
            margin: 4px 0;
        }
        .info-card .cheater-range {
            font-weight: 500;
            color: #d6e0ee;
        }
        .info-section {
            margin-top: 24px;
            background: rgba(26, 37, 54, 0.5);
            backdrop-filter: blur(4px);
            border-radius: 16px;
            padding: 18px 20px;
            border: 1px solid rgba(45, 63, 85, 0.25);
        }
        .info-section h3 {
            margin-bottom: 10px;
            color: #d6e0ee;
            font-weight: 600;
        }
        .info-section ul {
            list-style: none;
            padding-left: 0;
        }
        .info-section ul li {
            padding: 6px 0;
            border-bottom: 1px solid rgba(42, 54, 71, 0.3);
            font-size: 14px;
            color: #b0c2d6;
        }
        .info-section ul li:last-child { border-bottom: none; }
        .info-section ul li strong { color: #d6e0ee; }
        .info-section ul li a {
            color: #3f8bb3;
            text-decoration: none;
        }
        .info-section ul li a:hover { text-decoration: underline; }

        /* ===== ЧАТ ===== */
        .chat-container {
            display: flex;
            flex-direction: column;
            height: 500px;
            max-height: 70vh;
            background: rgba(15, 24, 35, 0.5);
            backdrop-filter: blur(8px);
            border-radius: 20px;
            border: 1px solid rgba(61, 87, 117, 0.2);
            overflow: hidden;
            margin-top: 10px;
            box-shadow: inset 0 0 40px rgba(0,0,0,0.2);
        }
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            scroll-behavior: smooth;
        }
        .chat-messages::-webkit-scrollbar {
            width: 6px;
        }
        .chat-messages::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.2);
            border-radius: 10px;
        }
        .chat-messages::-webkit-scrollbar-thumb {
            background: #3f8bb3;
            border-radius: 10px;
        }

        .message {
            max-width: 82%;
            padding: 10px 16px;
            border-radius: 16px;
            font-size: 14px;
            line-height: 1.5;
            animation: fadeIn 0.3s ease;
            word-wrap: break-word;
        }
        .message.user {
            align-self: flex-end;
            background: rgba(43, 108, 143, 0.25);
            border: 1px solid rgba(63, 139, 179, 0.25);
            color: #e8edf5;
        }
        .message.bot {
            align-self: flex-start;
            background: rgba(26, 40, 60, 0.6);
            border: 1px solid rgba(61, 87, 117, 0.2);
            color: #d6e0ee;
        }
        .message .msg-time {
            font-size: 10px;
            color: #6e8aa6;
            margin-top: 4px;
            text-align: right;
            opacity: 0.7;
        }
        .message.bot .msg-time {
            text-align: left;
        }

        .chat-input-area {
            display: flex;
            gap: 10px;
            padding: 12px 16px;
            background: rgba(15, 24, 35, 0.6);
            border-top: 1px solid rgba(61, 87, 117, 0.15);
            backdrop-filter: blur(4px);
            align-items: center;
        }
        .chat-input-area input {
            flex: 1;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(61, 87, 117, 0.3);
            color: #e8edf5;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 14px;
            outline: none;
            transition: border 0.2s;
        }
        .chat-input-area input:focus {
            border-color: #3f8bb3;
            box-shadow: 0 0 20px rgba(43, 108, 143, 0.1);
        }
        .chat-input-area .btn {
            padding: 8px 20px;
            font-size: 14px;
        }

        /* ===== МОДАЛЬНЫЕ ОКНА ===== */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(8px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 999;
            padding: 20px;
        }
        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: rgba(22, 34, 50, 0.95);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            max-width: 520px;
            width: 100%;
            padding: 28px 24px 32px;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(61, 87, 117, 0.25);
            animation: fadeUp 0.3s ease;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px) scale(0.96); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .modal h2 {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 6px;
            color: #d6e0ee;
        }
        .modal p {
            color: #a0b5cc;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-weight: 500;
            margin-bottom: 6px;
            color: #cbdae9;
            font-size: 14px;
        }

        .region-selector {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .region-selector label {
            display: flex;
            align-items: center;
            gap: 5px;
            background: rgba(15, 24, 35, 0.6);
            padding: 6px 14px;
            border-radius: 40px;
            cursor: pointer;
            border: 1px solid rgba(45, 63, 85, 0.4);
            transition: 0.15s;
            font-weight: 400;
            color: #c8d6e8;
            font-size: 14px;
            backdrop-filter: blur(4px);
        }
        .region-selector label:hover {
            background: rgba(29, 44, 62, 0.8);
            border-color: #3f8bb3;
        }
        .region-selector input[type="radio"] {
            accent-color: #3f8bb3;
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

        .modal input[type="number"] {
            background: rgba(15, 24, 35, 0.6);
            border: 1px solid rgba(45, 63, 85, 0.4);
            color: #e8edf5;
            padding: 8px 14px;
            border-radius: 30px;
            width: 100%;
            font-size: 14px;
            backdrop-filter: blur(4px);
            outline: none;
            transition: border 0.2s;
        }
        .modal input[type="number"]:focus {
            border-color: #3f8bb3;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        .modal-actions .btn {
            padding: 10px 20px;
            font-size: 14px;
        }

        .admin-panel .form-group-inline {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
        }
        .admin-panel .form-group-inline label { margin-bottom: 0; }
        .admin-panel input[type="number"] {
            background: rgba(15, 24, 35, 0.6);
            border: 1px solid rgba(45, 63, 85, 0.4);
            color: #e8edf5;
            padding: 6px 12px;
            border-radius: 30px;
            width: 80px;
            font-size: 14px;
            backdrop-filter: blur(4px);
        }
        .admin-panel input[type="password"] {
            background: rgba(15, 24, 35, 0.6);
            border: 1px solid rgba(45, 63, 85, 0.4);
            color: #e8edf5;
            padding: 8px 16px;
            border-radius: 30px;
            width: 100%;
            font-size: 14px;
            backdrop-filter: blur(4px);
        }

        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(22, 34, 50, 0.95);
            backdrop-filter: blur(12px);
            color: #e2ecfa;
            padding: 14px 28px;
            border-radius: 60px;
            font-size: 14px;
            font-weight: 500;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
            border: 1px solid rgba(61, 87, 117, 0.25);
            display: none;
            z-index: 1000;
            white-space: nowrap;
            max-width: 90%;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .toast.show {
            display: block;
            animation: fadeUp 0.3s ease;
        }

