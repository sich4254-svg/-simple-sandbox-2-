    <div class="toast" id="toast"></div>

    <script>
        (function() {
            'use strict';

            console.log('🚀 SSB2 Монитор — синхронизация между вкладками');

            // =============================================================
            //  1. КОНСТАНТЫ
            // =============================================================
            const REGIONS = [
                { id: 'eu', label: 'EU', fullName: 'Европа' },
                { id: 'usa', label: 'USA', fullName: 'США' },
                { id: 'as', label: 'AS', fullName: 'Азия' },
                { id: 'ru', label: 'RU', fullName: 'Россия' },
                { id: 'br', label: 'BR', fullName: 'Бразилия' },
                { id: 'uk', label: 'UK', fullName: 'Украина' }
            ];

            const DANGER_LEVELS = [
                { key: 'green', label: 'Спокойно', min: 0, max: 0, color: '#2e9b5e' },
                { key: 'yellow', label: 'Опасность есть', min: 1, max: 3, color: '#d4b84c' },
                { key: 'orange', label: 'Читеры есть', min: 5, max: 19, color: '#d97a2b' },
                { key: 'red', label: 'Невозможно играть', min: 20, max: Infinity, color: '#c53e3e' }
            ];

            const THRESHOLD = 5;
            const ADMIN_PASSWORD = '1488093чит';
            const COOLDOWN_MS = 3 * 60 * 1000;

            // =============================================================
            //  2. ХРАНИЛИЩЕ (localStorage + fallback)
            // =============================================================
            let memoryStorage = {};

            function isLocalStorageAvailable() {
                try {
                    const testKey = '__test__';
                    localStorage.setItem(testKey, 'test');
                    localStorage.removeItem(testKey);
                    return true;
                } catch (e) {
                    return false;
                }
            }

            const storageAvailable = isLocalStorageAvailable();

            function saveToStorage(key, data) {
                try {
                    if (storageAvailable) {
                        localStorage.setItem(key, JSON.stringify(data));
                    } else {
                        memoryStorage[key] = data;
                    }
                } catch (e) {
                    memoryStorage[key] = data;
                }
            }

            function loadFromStorage(key) {
                try {
                    if (storageAvailable) {
                        const saved = localStorage.getItem(key);
                        if (saved) return JSON.parse(saved);
                        return null;
                    } else {
                        return memoryStorage[key] || null;
                    }
                } catch (e) {
                    return memoryStorage[key] || null;
                }
            }

            // =============================================================
            //  3. СОСТОЯНИЕ (общее для всех)
            // =============================================================
            let cheaterCounts = {};
            let reportData = {};
            let processing = false; // флаг для предотвращения гонок

            function saveState() {
                saveToStorage('ss2_monitor_state', { cheaterCounts, reportData });
            }

            function loadState() {
                const parsed = loadFromStorage('ss2_monitor_state');
                if (!parsed) return false;
                let valid = true;
                REGIONS.forEach(r => {
                    if (!(r.id in parsed.cheaterCounts)) { valid = false; return; }
                    if (!(r.id in parsed.reportData)) { valid = false; return; }
                    parsed.cheaterCounts[r.id] = Number(parsed.cheaterCounts[r.id]) || 0;
                    if (!Array.isArray(parsed.reportData[r.id])) { valid = false; return; }
                    parsed.reportData[r.id] = parsed.reportData[r.id].map(Number).filter(n => !isNaN(n) && n >= 0);
                });
                if (!valid) return false;
                cheaterCounts = parsed.cheaterCounts;
                reportData = parsed.reportData;
                return true;
            }

            // =============================================================
            //  4. ИНИЦИАЛИЗАЦИЯ
            // =============================================================
            function initState() {
                if (!loadState()) {
                    REGIONS.forEach(r => {
                        cheaterCounts[r.id] = 0;
                        reportData[r.id] = [];
                    });
                    saveState();
                }
            }
            initState();

            // =============================================================
            //  5. КУЛДАУН (индивидуальный)
            // =============================================================
            const COOLDOWN_KEY = 'ss2_last_report_time_session';

            function getCooldownRemaining() {
                try {
                    const last = sessionStorage.getItem(COOLDOWN_KEY);
                    if (!last) return 0;
                    return Math.max(0, COOLDOWN_MS - (Date.now() - parseInt(last)));
                } catch (e) {
                    return 0;
                }
            }

            function isCooldownActive() { return getCooldownRemaining() > 0; }

            function setCooldown() {
                try {
                    sessionStorage.setItem(COOLDOWN_KEY, String(Date.now()));
                } catch (e) { /* ignore */ }
                updateCooldownUI();
            }

            let cooldownInterval = null;

            function updateCooldownUI() {
                const remaining = getCooldownRemaining();
                const display = document.getElementById('cooldownDisplay');
                const timeEl = document.getElementById('cooldownTime');
                const reportBtn = document.getElementById('reportBtn');
                if (!display || !timeEl || !reportBtn) return;

                if (remaining > 0) {
                    const mins = Math.floor(remaining / 60000);
                    const secs = Math.floor((remaining % 60000) / 1000);
                    timeEl.textContent = mins + ':' + secs.toString().padStart(2, '0');
                    display.classList.add('show');
                    reportBtn.disabled = true;
                    if (!cooldownInterval) {
                        cooldownInterval = setInterval(updateCooldownUI, 1000);
                    }
                } else {
                    display.classList.remove('show');
                    reportBtn.disabled = false;
                    if (cooldownInterval) {
                        clearInterval(cooldownInterval);
                        cooldownInterval = null;
                    }
                }
            }

            // =============================================================
            //  6. ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
            // =============================================================
            function getDangerLevel(count) {
                for (let lv of DANGER_LEVELS) {
                    if (count >= lv.min && count <= lv.max) return lv;
                }
                return DANGER_LEVELS[0];
            }
            function getColor(count) { return getDangerLevel(count).color; }
            function getPulseClass(count) { return 'pulse-' + getDangerLevel(count).key; }
            function getStatusText(count) { return getDangerLevel(count).label; }
            function average(arr) { return arr.length ? Math.round(arr.reduce((a, b) => a + b, 0) / arr.length) : 0; }

            // =============================================================
            //  7. РЕНДЕРИНГ
            // =============================================================
            function renderRegions(containerId, showReports, updateElementId) {
                const container = document.getElementById(containerId);
                const updateEl = document.getElementById(updateElementId);
                if (!container) return;

                let html = '';
                REGIONS.forEach(region => {
                    const id = region.id;
                    const count = cheaterCounts[id] || 0;
                    const color = getColor(count);
                    const status = getStatusText(count);
                    const pulseClass = getPulseClass(count);
                    const reports = reportData[id] || [];

                    let statsHtml = '';
                    if (showReports) {
                        const avg = average(reports);
                        statsHtml = `<div class="report-stats">
                            <span>📊 Сообщений: ${reports.length}</span>
                            ${reports.length > 0 ? `<span>📈 Среднее: ${avg}</span>` : ''}
                        </div>`;
                    }

                    html += `
                        <div class="region-card" data-region="${id}">
                            <div class="region-name">${region.fullName} <span class="label">${region.label}</span></div>
                            <div class="status-indicator">
                                <div class="circle ${pulseClass}" style="background:${color};"></div>
                                <span class="status-label">${status}</span>
                                <span class="cheater-count">👾 ${count} читер${count%10===1 && count%100!==11 ? '' : count%10>=2 && count%10<=4 && (count%100<10 || count%100>=20) ? 'а' : 'ов'}</span>
                                ${statsHtml}
                            </div>
                        </div>
                    `;
                });
                container.innerHTML = html;
                if (updateEl) {
                    updateEl.textContent = '⏱️ Обновлено: ' + new Date().toLocaleTimeString();
                }
            }

            function renderAll() {
                renderRegions('regionsContainerNews', true, 'lastUpdateNews');
                renderRegions('regionsContainerOnline', false, 'lastUpdateOnline');
            }

            // =============================================================
            //  8. ЛОГИКА СООБЩЕНИЙ (с защитой от гонок)
            // =============================================================
            function processReports(regionId) {
                if (processing) return false;
                processing = true;
                try {
                    const arr = reportData[regionId] || [];
                    if (arr.length >= THRESHOLD) {
                        const avg = average(arr);
                        cheaterCounts[regionId] = avg;
                        reportData[regionId] = [];
                        saveState();
                        renderAll();
                        const regionName = REGIONS.find(r => r.id === regionId).fullName;
                        showToast('📢 Регион ' + regionName + ' обновлён: ' + avg + ' читер' + (avg % 10 === 1 && avg % 100 !== 11 ? '' : avg % 10 >= 2 && avg % 10 <= 4 && (avg % 100 < 10 || avg % 100 >= 20) ? 'а' : 'ов'));
                        return true;
                    }
                    return false;
                } finally {
                    processing = false;
                }
            }

            function addReport(regionId, cheaterCount) {
                if (isCooldownActive()) {
                    const remaining = getCooldownRemaining();
                    const mins = Math.floor(remaining / 60000);
                    const secs = Math.floor((remaining % 60000) / 1000);
                    showToast('⏳ Подождите ' + mins + ':' + secs.toString().padStart(2, '0') + ' перед следующей отправкой.');
                    return;
                }

                const num = Math.min(50, Math.max(0, Math.round(cheaterCount)));
                if (!reportData[regionId]) reportData[regionId] = [];
                reportData[regionId].push(num);
                saveState();
                renderAll();

                if (!processReports(regionId)) {
                    const count = reportData[regionId].length;
                    const regionName = REGIONS.find(r => r.id === regionId).fullName;
                    showToast('📨 Сообщение для ' + regionName + ' (' + count + '/' + THRESHOLD + ')');
                }
                setCooldown();
            }

            // =============================================================
            //  9. АДМИНИСТРИРОВАНИЕ
            // =============================================================
            function adminSetRegion(regionId, val) {
                cheaterCounts[regionId] = Math.min(50, Math.max(0, val));
                reportData[regionId] = [];
                saveState();
                renderAll();
                const regionName = REGIONS.find(r => r.id === regionId).fullName;
                showToast('🔐 Админ: регион ' + regionName + ' установлен на ' + cheaterCounts[regionId] + ' читер' + (cheaterCounts[regionId] % 10 === 1 && cheaterCounts[regionId] % 100 !== 11 ? '' : cheaterCounts[regionId] % 10 >= 2 && cheaterCounts[regionId] % 10 <= 4 && (cheaterCounts[regionId] % 100 < 10 || cheaterCounts[regionId] % 100 >= 20) ? 'а' : 'ов'));
            }

            function adminResetReports(regionId) {
                reportData[regionId] = [];
                saveState();
                renderAll();
                const regionName = REGIONS.find(r => r.id === regionId).fullName;
                showToast('🧹 Накопленные данные для ' + regionName + ' сброшены');
            }

            // =============================================================
            //  10. МОДАЛЬНЫЕ ОКНА
            // =============================================================
            const reportModal = document.getElementById('reportModal');
            const adminModal = document.getElementById('adminModal');

            function buildRegionSelector(containerId, nameAttr, checkedId) {
                const container = document.getElementById(containerId);
                if (!container) return;
                let html = '';
                REGIONS.forEach(r => {
                    const checked = (r.id === (checkedId || 'eu')) ? 'checked' : '';
                    html += `
                        <label>
                            <input type="radio" name="${nameAttr}" value="${r.id}" ${checked}>
                            ${r.fullName} (${r.label})
                        </label>
                    `;
                });
                container.innerHTML = html;
            }

            function openReportModal() {
                if (isCooldownActive()) {
                    const remaining = getCooldownRemaining();
                    const mins = Math.floor(remaining / 60000);
                    const secs = Math.floor((remaining % 60000) / 1000);
                    showToast('⏳ Подождите ' + mins + ':' + secs.toString().padStart(2, '0') + ' перед следующей отправкой.');
                    return;
                }
                buildRegionSelector('reportRegionSelector', 'reportRegion', 'eu');
                const input = document.getElementById('reportCheaterCount');
                if (input) input.value = '';
                reportModal.classList.add('active');
            }

            function closeReportModal() {
                reportModal.classList.remove('active');
            }

            function openAdminModal() {
                const passInput = document.getElementById('adminPassword');
                const content = document.getElementById('adminContent');
                if (passInput) passInput.value = '';
                if (content) content.style.display = 'none';
                buildRegionSelector('adminRegionSelector', 'adminRegion', 'eu');
                adminModal.classList.add('active');
            }

            function closeAdminModal() {
                adminModal.classList.remove('active');
            }

            // =============================================================
            //  11. TOAST
            // =============================================================
            const toast = document.getElementById('toast');
            let toastTimeout;

            function showToast(text) {
                if (!toast) return;
                toast.textContent = text;
                toast.classList.add('show');
                clearTimeout(toastTimeout);
                toastTimeout = setTimeout(() => {
                    toast.classList.remove('show');
                }, 5000);
            }

            // =============================================================
            //  12. СИНХРОНИЗАЦИЯ МЕЖДУ ВКЛАДКАМИ (событие storage)
            // =============================================================
            window.addEventListener('storage', function(e) {
                if (e.key === 'ss2_monitor_state') {
                    console.log('🔄 Обнаружено изменение в другой вкладке, перезагружаем состояние...');
                    loadState();
                    renderAll();
                    updateCooldownUI();
                }
            });

            // =============================================================
            //  13. ИИ-ПОМОЩНИК
            // =============================================================
            const chatMessages = document.getElementById('chatMessages');
            const chatInput = document.getElementById('chatInput');
            const chatSendBtn = document.getElementById('chatSendBtn');
            let chatHistory = [];

            function getRegionStatus(regionId) {
                const count = cheaterCounts[regionId] || 0;
                const level = getDangerLevel(count);
                const status = level.label;
                const emoji = level.key === 'green' ? '🟢' : level.key === 'yellow' ? '🟡' : level.key === 'orange' ? '🟠' : '🔴';
                return `${emoji} ${status} (${count} читер${count%10===1 && count%100!==11 ? '' : count%10>=2 && count%10<=4 && (count%100<10 || count%100>=20) ? 'а' : 'ов'})`;
            }

            const regionMap = {
                'европа': 'eu', 'европе': 'eu', 'европейском': 'eu',
                'сша': 'usa', 'америка': 'usa',
                'азии': 'as', 'азия': 'as',
                'россии': 'ru', 'россия': 'ru', 'русском': 'ru',
                'бразилии': 'br', 'бразилия': 'br',
                'украине': 'uk', 'украина': 'uk'
            };

            function getBotResponse(userText) {
                const lower = userText.toLowerCase();

                if (lower.match(/\b(привет|здравствуй|здравствуйте|хай|hello|ку|салют|добрый день|доброе утро|добрый вечер)\b/)) {
                    return 'Привет! 👋 Я ИИ-помощник SSB2. Спрашивай о чём угодно — я помню наш разговор! 😊';
                }

                for (let [name, id] of Object.entries(regionMap)) {
                    if (lower.includes(name)) {
                        const region = REGIONS.find(r => r.id === id);
                        if (region) {
                            const status = getRegionStatus(id);
                            const reports = reportData[id] || [];
                            let extra = '';
                            if (reports.length > 0) {
                                extra = ` Сейчас накоплено ${reports.length} сообщений (среднее: ${average(reports)}).`;
                            }
                            return `📊 В регионе **${region.fullName} (${region.label})** сейчас ${status}.${extra} Если вы заметили читеров — сообщите через "Новости".`;
                        }
                    }
                }

                if (lower.match(/\b(безопасно|опасно|стоит ли играть|можно ли играть|заходить|играть сейчас|риск|лучше не играть)\b/)) {
                    const dangerousRegions = [];
                    REGIONS.forEach(r => {
                        const count = cheaterCounts[r.id] || 0;
                        const level = getDangerLevel(count);
                        if (level.key === 'red' || level.key === 'orange') {
                            dangerousRegions.push(`${r.fullName} (${level.label})`);
                        }
                    });
                    if (dangerousRegions.length === 0) {
                        return '✅ Сейчас во всех регионах спокойно (зелёный или жёлтый уровень). Играть безопасно! Но всегда следите за обновлениями.';
                    } else {
                        return `⚠️ Внимание! Опасность в регионах: ${dangerousRegions.join(', ')}. Рекомендуем избегать игры там. В остальных регионах ситуация стабильна. Проверяйте вкладку "Онлайн" для актуальной картины.`;
                    }
                }

                if (lower.match(/\b(кто создатель|кто разработал|создатель ссб|разработчик|автор игры|кто сделал)\b/)) {
                    return '🎮 Simple Sandbox 2 — это игра-песочница, созданная независимым разработчиком. Точное имя создателя не разглашается, но проект активно поддерживается сообществом. Следите за новостями в телеграм-канале "Радар ССБ2".';
                }

                if (lower.match(/\b(обновление|патч|новая версия|вышло обновление|что нового|изменения|фиксы)\b/)) {
                    return '🔄 Информация об обновлениях Simple Sandbox 2 обычно появляется в официальных каналах игры и в телеграм-канале "Радар ССБ2". Рекомендуем следить там за новостями. Наш мониторинг обновляется автоматически при поступлении сообщений от пользователей.';
                }

                if (lower.match(/\b(совет|как играть|стратегия|что делать|рекомендация|лучше|подсказка)\b/)) {
                    return '💡 Основные советы по Simple Sandbox 2:\n• Следите за уровнем опасности в регионах перед входом.\n• Если видите читеров — сообщайте через "Новости", чтобы помочь другим.\n• Используйте вкладку "Онлайн" для быстрой оценки ситуации.\n• В красных регионах играть крайне не рекомендуется.\n• Подписывайтесь на телеграм-канал "Радар ССБ2" для оперативных новостей.';
                }

                if (lower.match(/\b(история|динамика|как менялось|статистика|график|тренд)\b/)) {
                    return '📈 Наш мониторинг не хранит историю изменений, но вы можете видеть текущее состояние регионов на вкладках "Новости" и "Онлайн". Каждое сообщение пользователя влияет на усреднённое значение, которое обновляется после 5 сообщений.';
                }

                if (lower.match(/\b(сайт|мониторинг|как работает|принцип|зачем нужен|что это)\b/)) {
                    return '🌐 Этот сайт — мониторинг читеров для Simple Sandbox 2. Он собирает сообщения от игроков о количестве читеров в 6 регионах. После 5 сообщений вычисляется среднее арифметическое, и регион обновляется. Администратор может вручную корректировать данные. Все изменения сохраняются в вашем браузере.';
                }

                if (lower.match(/\b(телеграм|радар|канал|ссылка|тг)\b/)) {
                    return '📱 Телеграм-канал «Радар ССБ2»: https://t.me/rabar_ssb2 — там публикуются актуальные новости, обсуждения и полезная информация по игре. Подписывайтесь!';
                }

                if (lower.match(/\b(регионы|сколько регионов|какие регионы|список регионов|все регионы)\b/)) {
                    let regionsList = REGIONS.map(r => `${r.fullName} (${r.label})`).join(', ');
                    return `🌍 Доступны 6 регионов: ${regionsList}. Выберите нужный во вкладке "Новости" для отправки сообщения.`;
                }

                if (lower.match(/\b(уровни|цвета|кружки|пульсация|что означают цвета|цвет круга)\b/)) {
                    return '🎨 Уровни опасности:\n🟢 Зелёный — 0 читеров, спокойно.\n🟡 Жёлтый — 1-3 читера, опасность есть.\n🟠 Оранжевый — 5-19 читеров, читеры есть.\n🔴 Красный — 20+ читеров, играть невозможно.\nПульсация кружка усиливается с ростом опасности.';
                }

                if (lower.match(/\b(спасибо|благодарю|ты лучший|отлично|класс|супер)\b/)) {
                    return '😊 Всегда рад помочь! Если у тебя ещё есть вопросы по Simple Sandbox 2 или мониторингу — смело спрашивай. Удачи в игре!';
                }

                let lastRegionId = null;
                for (let i = chatHistory.length - 1; i >= 0; i--) {
                    const msg = chatHistory[i].toLowerCase();
                    for (let [name, id] of Object.entries(regionMap)) {
                        if (msg.includes(name)) {
                            lastRegionId = id;
                            break;
                        }
                    }
                    if (lastRegionId) break;
                }

                if (lastRegionId && (lower.match(/\b(а там|а в нем|а на нем|а что там|и что|ну и|а как)\b/) || lower.length < 20)) {
                    const region = REGIONS.find(r => r.id === lastRegionId);
                    if (region) {
                        const status = getRegionStatus(lastRegionId);
                        return `📊 По региону **${region.fullName} (${region.label})** сейчас ${status}. Хотите что-то ещё узнать?`;
                    }
                }

                return '🤔 Я пока не знаю ответа на этот вопрос, но могу помочь по темам: игра Simple Sandbox 2, читеры, регионы, уровни опасности, мониторинг, создатель игры, безопасность, обновления, советы. Попробуй переформулировать вопрос или спроси что-то из этих тем.';
            }

            function addMessage(text, sender) {
                const msgDiv = document.createElement('div');
                msgDiv.classList.add('message', sender);
                const now = new Date();
                const timeStr = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
                const formattedText = text.replace(/\n/g, '<br>');
                msgDiv.innerHTML = formattedText + `<div class="msg-time">${timeStr}</div>`;
                chatMessages.appendChild(msgDiv);
                chatMessages.scrollTop = chatMessages.scrollHeight;
                if (sender === 'user') {
                    chatHistory.push(text);
                    if (chatHistory.length > 15) chatHistory.shift();
                }
            }

            function handleChatSend() {
                const text = chatInput.value.trim();
                if (!text) {
                    showToast('⚠️ Напишите вопрос.');
                    return;
                }
                addMessage(text, 'user');
                chatInput.value = '';
                const response = getBotResponse(text);
                setTimeout(() => {
                    addMessage(response, 'bot');
                }, 400);
            }

            chatSendBtn.addEventListener('click', handleChatSend);
            chatInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    handleChatSend();
                }
            });

            // =============================================================
            //  14. ПОДКЛЮЧЕНИЕ ОБРАБОТЧИКОВ
            // =============================================================
            function init() {
                console.log('🚀 Финальная инициализация...');

                document.getElementById('reportBtn').addEventListener('click', openReportModal);
                document.getElementById('cancelReportBtn').addEventListener('click', closeReportModal);
                document.getElementById('sendReportBtn').addEventListener('click', function() {
                    const selectedRegion = document.querySelector('input[name="reportRegion"]:checked');
                    const inputCount = document.getElementById('reportCheaterCount');
                    if (!selectedRegion) {
                        showToast('⚠️ Выберите регион.');
                        return;
                    }
                    const count = parseInt(inputCount ? inputCount.value : '');
                    if (isNaN(count) || count < 0 || count > 50) {
                        showToast('⚠️ Введите число от 0 до 50.');
                        return;
                    }
                    addReport(selectedRegion.value, count);
                    closeReportModal();
                });

                document.getElementById('adminBtn').addEventListener('click', openAdminModal);
                document.getElementById('cancelAdminBtn').addEventListener('click', closeAdminModal);

                const adminPassword = document.getElementById('adminPassword');
                const adminContent = document.getElementById('adminContent');
                adminPassword.addEventListener('input', function() {
                    if (this.value === ADMIN_PASSWORD) {
                        adminContent.style.display = 'block';
                        showToast('🔓 Доступ разрешён');
                    } else {
                        adminContent.style.display = 'none';
                    }
                });

                document.getElementById('adminApplyBtn').addEventListener('click', function() {
                    const selectedRegion = document.querySelector('input[name="adminRegion"]:checked');
                    if (!selectedRegion) {
                        showToast('⚠️ Выберите регион');
                        return;
                    }
                    const val = parseInt(document.getElementById('adminCheaterCount').value);
                    if (isNaN(val) || val < 0) {
                        showToast('⚠️ Введите корректное число');
                        return;
                    }
                    adminSetRegion(selectedRegion.value, val);
                    closeAdminModal();
                });

                document.getElementById('adminResetReportsBtn').addEventListener('click', function() {
                    const selectedRegion = document.querySelector('input[name="adminRegion"]:checked');
                    if (!selectedRegion) {
                        showToast('⚠️ Выберите регион');
                        return;
                    }
                    adminResetReports(selectedRegion.value);
                    closeAdminModal();
                });

                reportModal.addEventListener('click', function(e) {
                    if (e.target === reportModal) closeReportModal();
                });
                adminModal.addEventListener('click', function(e) {
                    if (e.target === adminModal) closeAdminModal();
                });

                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape') {
                        if (reportModal.classList.contains('active')) closeReportModal();
                        if (adminModal.classList.contains('active')) closeAdminModal();
                    }
                });

                document.querySelectorAll('.tab-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const tabId = this.dataset.tab;
                        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
                        this.classList.add('active');
                        document.getElementById(tabId).classList.add('active');
                        renderAll();
                        if (tabId === 'tab-chat') {
                            setTimeout(() => chatInput.focus(), 100);
                        }
                    });
                });

                renderAll();
                updateCooldownUI();

                setTimeout(() => {
                    showToast('🛡️ SSB2 Монитор готов! Данные синхронизируются между вкладками.');
                }, 800);

                console.log('✅ Финальная инициализация завершена');
            }

            // =============================================================
            //  15. ЗАПУСК
            // =============================================================
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }

        })();
    </script>

</body>
</html>
